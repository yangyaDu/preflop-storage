{
  "name": "preflop-storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:binary": "bun run src/scheme1/cli/build-binary.ts",
    "build:scheme2": "bun run src/scheme2/cli/build-binary.ts",
    "build:native": "bun run scripts/build-native.ts",
    "build:native:win": "bun run scripts/build-native.ts --target x86_64-pc-windows-msvc",
    "build:native:linux": "bun run scripts/build-native.ts --target x86_64-unknown-linux-gnu",
    "build:native:mac:arm64": "bun run scripts/build-native.ts --target aarch64-apple-darwin",
    "build:native:mac:x64": "bun run scripts/build-native.ts --target x86_64-apple-darwin",
    "query:hand": "bun run src/scheme1/cli/query-hand.ts",
    "query:scheme2": "bun run src/scheme2/cli/query-hand.ts",
    "analyze:sqlite": "bun run src/scheme1/cli/analyze-sqlite.ts",
    "analyze:binary": "bun run src/scheme1/cli/analyze-binary.ts",
    "analyze": "bun run analyze:sqlite && bun run analyze:binary --sqlite-report reports/sqlite-analysis.json --md reports/storage-analysis.md",
    "verify:binary": "bun run src/scheme1/cli/verify-binary.ts",
    "verify:scheme2": "bun run src/scheme2/cli/verify-binary.ts",
    "verify:scheme2:cross": "bun run verify:scheme2 --mode cross --verify-checksum",
    "benchmark:sqlite": "bun run src/scheme1/cli/benchmark-sqlite.ts",
    "benchmark:binary": "bun run src/scheme1/cli/benchmark-binary.ts",
    "benchmark:scheme2": "bun run src/scheme2/cli/benchmark-binary.ts",
    "benchmark:compare": "bun run src/scheme1/cli/benchmark-compare.ts",
    "benchmark": "bun run benchmark:sqlite && bun run benchmark:binary && bun run benchmark:compare",
    "test": "bun test",
    "fmt:native:check": "cargo fmt --manifest-path native-addon/Cargo.toml --check",
    "test:native": "cargo test --manifest-path native-addon/Cargo.toml",
    "check:native": "bun run fmt:native:check && bun run test:native",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check": "bun run typecheck && bun run lint && bun test",
    "check:release": "bun run check && bun run check:native && bun run verify:scheme2 --mode standalone --verify-checksum",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/bun": "latest",
    "eslint": "latest",
    "husky": "^9.1.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "latest"
  }
}
